# --- Portal auth (@logto/next) ---
# OIDC app of THIS portal in Logto (Traditional Web / Next.js App Router).
LOGTO_ENDPOINT=https://logto.idp.tripleenable.com/
LOGTO_APP_ID=<portal-oidc-app-id>
LOGTO_APP_SECRET=<portal-oidc-app-secret>
# 32+ random chars, used to encrypt the session cookie.
LOGTO_COOKIE_SECRET=<random-32-chars>
# Public base URL of this portal (http://localhost:3000 in dev).
LOGTO_BASE_URL=http://localhost:3000

# Public (browser-visible) copy of the Logto endpoint, used by the UI to
# render endpoint URLs and SDK snippets.
NEXT_PUBLIC_LOGTO_ENDPOINT=https://logto.idp.tripleenable.com/

# --- Management API (server-side only, never exposed to the browser) ---
LOGTO_M2M_CLIENT_ID=<m2m-app-id>
LOGTO_M2M_CLIENT_SECRET=<m2m-app-secret>
LOGTO_MANAGEMENT_API_RESOURCE=https://default.logto.app/api
